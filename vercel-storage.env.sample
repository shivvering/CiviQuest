# Copy to .env.local (never commit real values).
#
# POSTGRES_URL: Vercel → Project → Storage → Neon Postgres → connection string,
#   or `npx vercel env pull .env.local` to fetch everything at once.
# After saving, run once: npm run setup-db
#
# TEACHER_CODE: shared access code for the /teacher dashboard. Must match the
#   TEACHER_CODE env var on Vercel (`npx vercel env add TEACHER_CODE production`).

POSTGRES_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
TEACHER_CODE=choose-a-code
